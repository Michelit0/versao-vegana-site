---
import { Image } from 'astro:assets';
import { ArrowRight, HeartHandshake, Leaf, MessageCircle, Sparkles, Utensils } from '@lucide/astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import Callout from '../components/Callout.astro';
import heroImage from '../assets/images/mesa-vegetal.jpg';
import { brandValues, contact, orderPaths, products, trustSignals } from '../content/siteContent';

const title = 'Versão Vegana | Culinária brasileira inclusiva em Sobradinho';
const description = 'Comida brasileira em versões veganas, encomendas, congelados e eventos em Sobradinho e região. Peça ou monte uma prévia pelo WhatsApp.';
---

<BaseLayout title={title} description={description}>
  <section class="home-hero">
    <Image
      class="home-hero-image"
      src={heroImage}
      alt="Mesa com diferentes preparos vegetais coloridos para compartilhar"
      widths={[960, 1440, 2200]}
      sizes="100vw"
      loading="eager"
    />
    <div class="home-hero-overlay"></div>
    <div class="home-hero-content">
      <p class="eyebrow eyebrow-light">Culinária inclusiva em Sobradinho</p>
      <h1>Versão Vegana</h1>
      <p>
        Comida brasileira, afetiva e 100% vegetal. Para o almoço de hoje, a semana no congelador
        ou uma mesa inteira de gente feliz.
      </p>
      <div class="hero-actions">
        <a class="button button-cream" href={contact.whatsappUrl} target="_blank" rel="noreferrer">
          <MessageCircle size={20} aria-hidden="true" />
          Fazer pedido
        </a>
        <a class="button button-outline-light" href="/orcamento">
          Montar pré-orçamento <ArrowRight size={18} aria-hidden="true" />
        </a>
      </div>
      <div class="hero-signals">
        <span><Leaf size={17} aria-hidden="true" /> 100% vegetal</span>
        <span><HeartHandshake size={17} aria-hidden="true" /> Feita para incluir</span>
        <span><Utensils size={17} aria-hidden="true" /> Sabor brasileiro</span>
      </div>
    </div>
  </section>

  <section class="trust-strip page-shell" aria-label="Informações de atendimento">
    {trustSignals.map((signal) => <span>{signal}</span>)}
  </section>

  <section class="section page-shell intent-section">
    <div class="section-heading centered">
      <p class="eyebrow">O que você precisa hoje?</p>
      <h2>Chegue ao pedido certo sem dar voltas</h2>
      <p>Escolha o caminho e a gente continua a conversa com você.</p>
    </div>
    <div class="intent-grid">
      {orderPaths.map((path, index) => (
        <article class="intent-item">
          <span class="intent-number">0{index + 1}</span>
          <h3>{path.title}</h3>
          <p>{path.text}</p>
          <a href={path.href} target={path.href.startsWith('http') ? '_blank' : undefined} rel="noreferrer">
            {path.label} <ArrowRight size={17} aria-hidden="true" />
          </a>
        </article>
      ))}
    </div>
  </section>

  <section class="section section-soft">
    <div class="page-shell">
      <div class="section-heading split-heading">
        <div>
          <p class="eyebrow">Sabores da casa</p>
          <h2>Receitas conhecidas, em uma nova versão</h2>
        </div>
        <p>
          Comida vegetal não precisa parecer distante. A proposta é reconhecer o prato, sentir o tempero e
          descobrir uma maneira diferente de viver aquele sabor.
        </p>
      </div>
      <div class="product-grid product-grid-featured">
        {products.slice(0, 3).map((product) => <ProductCard product={product} />)}
      </div>
      <p class="image-disclaimer">Imagens ilustrativas. A apresentação dos pratos pode variar.</p>
      <div class="section-action">
        <a class="button button-outline" href="/cardapio">
          Conhecer o cardápio <ArrowRight size={18} aria-hidden="true" />
        </a>
      </div>
    </div>
  </section>

  <section class="section page-shell inclusion-section">
    <div class="inclusion-copy">
      <p class="eyebrow">Culinária inclusiva</p>
      <h2>Uma mesa boa é aquela em que mais gente consegue sentar</h2>
      <p>
        A Versão Vegana adapta referências da culinária brasileira para uma cozinha vegetal, acolhendo escolhas
        conscientes e conversando com cuidado sobre necessidades alimentares.
      </p>
      <p class="attention-note">
        Em caso de alergia ou restrição severa, informe a equipe antes do pedido para confirmar ingredientes e processo de preparo.
      </p>
      <a class="text-link" href="/sobre">Conheça a nossa história <ArrowRight size={17} aria-hidden="true" /></a>
    </div>
    <div class="value-list">
      {brandValues.map((value) => (
        <article>
          <Sparkles size={21} aria-hidden="true" />
          <div>
            <h3>{value.title}</h3>
            <p>{value.text}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="cerrado-home">
    <div class="page-shell cerrado-home-inner">
      <div>
        <p class="eyebrow eyebrow-light">Cerrado no presente</p>
        <h2>Comer também é escolher que território queremos fortalecer</h2>
      </div>
      <div>
        <p>
          Baru, pequi, jatobá e outros ingredientes nativos carregam cultura, biodiversidade e possibilidades de
          renda local. A Versão Vegana quer aproximar esses sabores do cotidiano.
        </p>
        <a class="button button-cream" href="/cerrado">
          Conhecer essa proposta <ArrowRight size={18} aria-hidden="true" />
        </a>
      </div>
    </div>
  </section>

  <section class="section page-shell event-preview">
    <div class="event-preview-copy">
      <p class="eyebrow">Encomendas e eventos</p>
      <h2>Do encontro pequeno ao buffet, a produção começa com planejamento</h2>
      <p>
        Conte quantas pessoas serão atendidas, quando será o evento e quais formatos fazem sentido.
        O simulador organiza uma primeira conversa, e a equipe confirma tudo pelo WhatsApp.
      </p>
      <div class="inline-actions">
        <a class="button button-primary" href="/orcamento">Montar pré-orçamento</a>
        <a class="button button-outline" href="/eventos">Ver como funciona</a>
      </div>
    </div>
    <div class="event-preview-visual">
      <Image
        src={heroImage}
        alt="Mesa compartilhada com variedade de pratos vegetais"
        widths={[640, 960]}
        sizes="(max-width: 800px) 100vw, 45vw"
        loading="eager"
      />
    </div>
  </section>

  <Callout />
</BaseLayout>
